# =====================================================
#  API de Detección de Smishing — Variables de entorno
#  Copia este archivo como .env y completa los valores
# =====================================================

# Puerto donde se expone la API
PORT=6000

# --- Base de datos MySQL ---
DB_HOST=localhost
DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña
DB_NAME=modelo
DB_PORT=3306    # Puerto de conexión a MySQL

# --- Autenticación ---
# Token fijo para el header X-API-Key
# Cámbialo por un valor seguro en producción
API_KEY=smishing-secret-token-2024
