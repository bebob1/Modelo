# =====================================================
#  API de Detección de Smishing — Variables de entorno
#  Copia este archivo como .env y completa los valores
# =====================================================

# --- Base de datos MySQL ---
DB_HOST=localhost
DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña
DB_NAME=modelo
PORT=3306       # Puerto de conexión a MySQL
DB_PORT=3306    # Alias alternativo (se usa PORT si está definido)

# --- Autenticación ---
# Token fijo para el header X-API-Key
# Cámbialo por un valor seguro en producción
API_KEY=smishing-secret-token-2024

# Nota: el puerto de la API está fijo en 6000 (no se configura aquí)
